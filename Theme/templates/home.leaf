#extend("base"):
#export("content"):
<div class="container"><div><div class="d-flex mx-auto align-items-center justify-content-center" aria-label="Vapor" id="vapor-hero-logo"><span id="vapor-hero-logo-mark" aria-hidden="true"></span><span id="vapor-hero-logo-text">Vapor</span></div><h1 class="main-title">#localise("home.hero.title")</h1><h3 class="main-page-caption d-flex mx-auto">#localise("home.hero.caption")</h3><div class="main-page-callout-buttons d-flex align-items-center justify-content-center flex-column flex-lg-row"><div class="w-mobile-100"><a href="https://docs.vapor.codes/" target="_blank" id="main-page-callout-button-link" class="btn btn-primary w-mobile-100">#localise("cta.getStarted")</a></div><div class="d-flex align-items-center ms-lg-5"><button class="btn btn-link btn-secondary-link"><a href="https://github.com/vapor/vapor" class="d-flex align-items-center"><span class="vapor-icon icon-github-line icon-secondary btn-icon me-2" aria-hidden="true"></span><span id="main-page-callout-stars-count" data-stars-template="#localise("home.hero.stars")">#localise("home.hero.starsLoading")</span></a></button></div></div><div class="main-code-demo mx-auto"><pre><code class="language-swift">import Vapor

let app = try await Application.make(.detect())

app.get("hello") { req in
    "Hello, world!"
}

try await app.execute()







</code></pre></div></div><div class="used-by-companies"><h5 class="used-by-caption">#localise("home.companies.caption")</h5><div class="d-flex flex-row flex-wrap align-items-center justify-content-center used-by-companies-items"><div class="used-by-item"><a href="https://johnlewis.com" target="_blank" class="used-by-logo"><span class="used-by-icon icon-john-lewis" title="John Lewis" aria-label="John Lewis"><span class="visually-hidden">John Lewis</span></span></a></div><div class="used-by-item"><a href="https://swiftpackageindex.com" target="_blank" class="used-by-logo"><span class="used-by-icon icon-swift-package-index" title="Swift Package Index" aria-label="Swift Package Index"><span class="visually-hidden">Swift Package Index</span></span></a></div><div class="used-by-item"><a href="https://allegro.pl" target="_blank" class="used-by-logo"><span class="used-by-icon icon-allegro" title="Allegro" aria-label="Allegro"><span class="visually-hidden">Allegro</span></span></a></div></div></div><div class="main-site-packages-list"><h2 class="main-site-section-header">#localise("home.packages.title")</h2><p class="caption">#localise("home.packages.caption")</p><div class="main-site-packages-grid row row-cols-1 row-cols-lg-2 gx-5"><div class="col"><div class="card h-100 vapor-feature-card"><div><span class="vapor-icon feature-card-icon icon-server-04"></span><h3 class="card-title">Vapor</h3><p class="card-text">#localise("home.packages.vapor.description")</p><a href="https://docs.vapor.codes/" target="_blank" class="learn-more-link">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div></div><div class="col"><div class="card h-100 vapor-feature-card"><div><span class="vapor-icon feature-card-icon icon-database-03"></span><h3 class="card-title">Fluent</h3><p class="card-text">#localise("home.packages.fluent.description")</p><a href="https://docs.vapor.codes/fluent/overview/" target="_blank" class="learn-more-link">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div></div><div class="col"><div class="card h-100 vapor-feature-card"><div><span class="vapor-icon feature-card-icon icon-key-01"></span><h3 class="card-title">JWT</h3><p class="card-text">#localise("home.packages.jwt.description")</p><a href="https://docs.vapor.codes/security/jwt/" target="_blank" class="learn-more-link">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div></div><div class="col"><div class="card h-100 vapor-feature-card"><div><span class="vapor-icon feature-card-icon icon-code-browser"></span><h3 class="card-title">Leaf</h3><p class="card-text">#localise("home.packages.leaf.description")</p><a href="https://docs.vapor.codes/leaf/overview/" target="_blank" class="learn-more-link">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div></div></div></div><div class="main-site-features"><div class="row row-cols-1 row-cols-lg-2 align-items-center"><div class="col order-2 order-lg-1 g-lg-0" id="performance"><div class="col order-2 order-lg-1 g-lg-0"><div class="code-example-explainer"><span class="vapor-icon icon-dataflow-03"></span><h2>#localise("home.features.performance.title")</h2><p>#localise("home.features.performance.description")</p><button class="btn btn-primary w-mobile-100"><a href="https://docs.vapor.codes/" target="_blank">#localise("cta.getStarted")<span class="vapor-icon icon-chevron-right"></span></a></button></div></div></div><div class="col order-1 order-lg-2 g-lg-0 position-relative"><div class="code-example"><pre><code class="language-swift">app.get("todos", ":id") { req async throws -&gt; Todo in
  let id: UUID = try req.parameters.require("id")

  guard
    let todo = try await Todo.find(id, on: req.db)
  else {
    throw Abort(.notFound)
  }

  return todo
}</code></pre></div><div class="code-outline-right"></div></div></div><div class="row row-cols-1 row-cols-lg-2 align-items-center"><div class="col order-2 g-lg-0"><div class="col order-2 order-lg-1 g-lg-0"><div class="code-example-explainer"><span class="vapor-icon icon-brackets-check"></span><h2>#localise("home.features.confidence.title")</h2><p>#localise("home.features.confidence.description")</p><button class="btn btn-primary w-mobile-100"><a href="https://docs.vapor.codes/" target="_blank">#localise("cta.getStarted")<span class="vapor-icon icon-chevron-right"></span></a></button></div></div></div><div class="col order-1 g-lg-0 position-relative"><div class="code-example errored"><pre><code class="language-swift">func search(req: Request) async throws -&gt; [Todo] {
  let name: String = try req.query.get(at: "name")

  let results = try await Todo.query(on: req.db)
    .filter(\.$number == name)
    .all()

  return results
}</code></pre></div><div class="code-outline-left"></div><div class="code-error"><div class="code-error-sidebar"><span class="vapor-icon icon-alert-octagon" aria-hidden="true"></span></div><span class="code-error-message">Binary operator '==' cannot be applied to operands of type 'KeyPath&lt;Todo,
FieldProperty&lt;Todo, Int&gt;&gt;' and 'String'</span></div></div></div></div><div class="row row-cols-1 row-cols-lg-2 align-items-center" id="integrations"><div class="col order-2 order-lg-1 mt-5 mt-lg-0"><div class="code-example-explainer"><span>#localise("home.integrations.label")</span><h2>#localise("home.integrations.title")</h2><p>#localise("home.integrations.description")</p><button class="btn btn-primary w-mobile-100"><a href="https://docs.vapor.codes/" target="_blank">#localise("cta.getStarted")<span class="vapor-icon icon-chevron-right" aria-hidden="true"></span></a></button></div></div><div class="col order-1 order-lg-2"><img src="https://design.vapor.codes/images/integrations.png" alt="Vapor Integrations" class="img-fluid" id="integrations-image"/></div></div><div class="row row-cols-1 row-cols-lg-2" id="showcase"><div class="showcase-header"><h3>#localise("home.showcase.title")</h3><button class="btn d-none d-lg-block"><a href="/showcase" class="text-decoration-none">#localise("home.showcase.seeFullList")<span class="ms-2 vapor-icon icon-chevron-right" aria-hidden="true"></span></a></button></div><div class="showcase-cards scrollable" id="home-page-showcase-cards-list"><div class="card" id="swiftfiddle-card"><img src="https://design.vapor.codes/images/swiftfiddle-card.png" alt="SwiftFiddle Card" class="card-img-top"/><div class="card-body d-flex flex-column"><h5 class="card-title">SwiftFiddle</h5><p class="card-text">SwiftFiddle is an online playground for creating, sharing and embedding Swift fiddles</p><a href="https://swiftfiddle.com" class="btn mt-auto">#localise("cta.seeInAction")<span class="vapor-icon icon-arrow-narrow-up-right"></span></a></div></div><div class="card" id="swiftpackageindex-card"><img src="/static/images/showcase/swift-package-index.png" alt="SwiftPackageIndex Card" class="card-img-top"/><div class="card-body d-flex flex-column"><h5 class="card-title">SwiftPackageIndex</h5><p class="card-text">The Swift Package Index is a searchable index of Swift packages and their compatibility with various platforms.</p><a href="https://swiftpackageindex.com" class="btn mt-auto">#localise("cta.seeInAction")<span class="vapor-icon icon-arrow-narrow-up-right"></span></a></div></div><div class="card" id="underway-nyc-card"><img src="https://design.vapor.codes/images/underway-nyc-card.png" alt="Underway NYC Card" class="card-img-top"/><div class="card-body d-flex flex-column"><h5 class="card-title">Underway NYC</h5><p class="card-text">Quickly locate yourself on the official MTA map of NYC and get real-time train arrivals at that subway stop</p><a href="https://www.underway.nyc" class="btn mt-auto">#localise("cta.seeInAction")<span class="vapor-icon icon-arrow-narrow-up-right"></span></a></div></div><div class="card" id="litmaps-card"><img src="/static/images/showcase/litmaps.png" alt="Litmaps Card" class="card-img-top"/><div class="card-body d-flex flex-column"><h5 class="card-title">Litmaps</h5><p class="card-text">Litmaps is a browser-based research platform designed for clarity, comprehensiveness, and collaboration.</p><a href="https://litmaps.com" class="btn mt-auto">#localise("cta.seeInAction")<span class="vapor-icon icon-arrow-narrow-up-right"></span></a></div></div></div><div class="btn-group scroll-button-group" data-scrollable="home-page-showcase-cards-list"><button class="arrow-button left-scroll-button"><span class="vapor-icon icon-arrow-left" aria-label="#localise("home.showcase.prev")"><span class="visually-hidden">#localise("home.showcase.prev")</span></span></button><button class="arrow-button right-scroll-button"><span class="vapor-icon icon-arrow-right" aria-label="#localise("home.showcase.next")"><span class="visually-hidden">#localise("home.showcase.next")</span></span></button></div></div><div class="row row-cols-1 row-cols-lg-2" id="discord"><div class="col"><img src="https://design.vapor.codes/images/discord-chat.png" alt="Vapor Discord server" class="img-fluid" id="discord-chat-image"/></div><div class="col"><div class="col order-2 order-lg-1 g-lg-0"><div class="px-4 px-lg-0"><h2>#localise("home.discord.title")</h2><p>#localise("home.discord.description")</p><button class="btn btn-primary w-mobile-100"><a href="https://vapor.team/" target="_blank">#localise("footer.joinDiscord")</a></button><a href="https://github.com/vapor/vapor" class="ms-3 learn-more-link mt-lg-0 mt-3 mb-lg-0 mb-3">#localise("home.discord.contribute")<span class="vapor-icon icon-chevron-right" aria-hidden="true"></span></a></div></div></div></div><div class="row row-cols-1 row-cols-lg-2 align-items-center" id="api-docs"><div class="col order-2 order-lg-1 mt-5 mt-lg-0"><h2 class="d-none d-lg-block">#localise("home.apiDocs.title")</h2><button class="btn btn-primary w-mobile-100"><a href="https://docs.vapor.codes/" target="_blank">#localise("cta.getStarted")</a></button><a href="https://api.vapor.codes/" target="_blank" class="ms-3 learn-more-link mt-lg-0 mt-3 mb-lg-0 mb-3">#localise("home.apiDocs.goToApiDocs")<span class="vapor-icon icon-chevron-right" aria-hidden="true"></span></a></div><div class="col items-list order-1 order-lg-2"><div><h2 class="d-lg-none px-4">#localise("home.apiDocs.title")</h2><ul class="px-4 p-lg-0"><li><span class="align-middle vapor-icon icon-check-circle icon-secondary me-2 d-inline-block" aria-hidden="true"></span><span class="align-middle">#localise("home.apiDocs.item1")</span></li><li><span class="align-middle vapor-icon icon-check-circle icon-secondary me-2 d-inline-block" aria-hidden="true"></span><span class="align-middle">#localise("home.apiDocs.item2")</span></li><li><span class="align-middle vapor-icon icon-check-circle icon-secondary me-2 d-inline-block" aria-hidden="true"></span><span class="align-middle">#localise("home.apiDocs.item3")</span></li><li><span class="align-middle vapor-icon icon-check-circle icon-secondary me-2 d-inline-block" aria-hidden="true"></span><span class="align-middle">#localise("home.apiDocs.item4")</span></li></ul></div></div></div><div class="container"><div class="row" id="sponsors"><div id="sponsors-header"><h3>#localise("home.sponsors.title")</h3><a href="https://github.com/sponsors/vapor" class="btn btn-secondary">#localise("home.sponsors.becomeSupporter")</a></div><div class="sponsors-list" id="home-page-sponsors-list"><div class="card"><div class="card-body d-flex flex-column"><img src="/static/images/sponsors/brokenhands.png" alt="Broken Hands" class="card-img-top"/><h5 class="card-title">Broken Hands</h5><p class="card-text">Providing Vapor training and consulting for clients around the world.</p><a href="https://www.brokenhands.io/" target="_blank" class="learn-more-link mt-auto">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div><div class="card"><div class="card-body d-flex flex-column"><img src="/static/images/sponsors/omrd.png" alt="omrd" class="card-img-top"/><h5 class="card-title">omrd</h5><p class="card-text">omrd provides consultation services for dental elated scans.</p><a href="https://omrd.com" target="_blank" class="learn-more-link mt-auto">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div><div class="card"><div class="card-body d-flex flex-column"><img src="/static/images/sponsors/emerge-tools.png" alt="Emerge Tools" class="card-img-top"/><h5 class="card-title">Emerge Tools</h5><p class="card-text">Emerge Tools is a suite of revolutionary products designed to supercharge mobile apps and the teams that build them.</p><a href="https://www.emergetools.com" target="_blank" class="learn-more-link mt-auto">#localise("cta.learnMore")<span class="vapor-icon icon-chevron-right"></span></a></div></div></div><div class="btn-group scroll-button-group" data-scrollable="home-page-sponsors-list"><button class="arrow-button left-scroll-button"><span class="vapor-icon icon-arrow-left" aria-label="#localise("home.sponsors.prev")"><span class="visually-hidden">#localise("home.sponsors.prev")</span></span></button><button class="arrow-button right-scroll-button" aria-label="#localise("home.sponsors.next")"><span class="vapor-icon icon-arrow-right"><span class="visually-hidden">#localise("home.sponsors.next")</span></span></button></div></div></div></div>
#endexport
